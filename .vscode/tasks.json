{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "编译并运行",
            "type": "shell",
            "command": "g++ -std=c++17 -O2 -Wall -Wextra -g -I'${workspaceFolder}' '${file}' -o '${fileDirname}/${fileBasenameNoExtension}' && '${fileDirname}/${fileBasenameNoExtension}'",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "dedicated"
            }
        },
        {
            "label": "编译并运行 (文件输入)",
            "type": "shell",
            "command": "g++ -std=c++17 -O2 -Wall -Wextra -g -I'${workspaceFolder}' '${file}' -o '${fileDirname}/${fileBasenameNoExtension}' && '${fileDirname}/${fileBasenameNoExtension}' < input.txt",
            "group": {
                "kind": "test"
            },
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "dedicated"
            }
        }
    ]
}
